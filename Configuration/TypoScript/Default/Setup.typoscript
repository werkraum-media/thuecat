module {
    tx_thuecat {
        view {
            templateRootPaths {
                10 = EXT:thuecat/Resources/Private/Templates/Backend
            }
            layoutRootPaths {
                10 = EXT:thuecat/Resources/Private/Layouts
            }
        }
    }
}

plugin.tx_thuecat {
    view {
        templateRootPaths.10 = EXT:thuecat/Resources/Private/Templates/
        partialRootPaths.10 = EXT:thuecat/Resources/Private/Partials/
        layoutRootPaths.10 = EXT:thuecat/Resources/Private/Layouts/
    }
}


page = PAGE
page.10 < styles.content.get

plugin.tx_thuecat {
    view {
        templateRootPaths.10 = EXT:thuecat/Resources/Private/Templates/
    }
    settings {
        itemsPerPage = 10
    }
}

tt_content.werkraummedia_thuecatattractionlist = EXTBASEPLUGIN

page = PAGE
page.10 < styles.content.get

plugin.tx_thuecat {
    view {
        templateRootPaths.10 = EXT:thuecat/Resources/Private/Templates/
    }
    settings {
        page.pid.thuecat_attraction_search = 10
    }
}

tt_content.werkraummedia_thuecatattractionlist = EXTBASEPLUGIN
tt_content.werkraummedia_thuecatattractionlist {
    extensionName = ThueCat
    pluginName = TouristAttractionList
}

tt_content.werkraummedia_thuecatattractionsearch = EXTBASEPLUGIN
tt_content.werkraummedia_thuecatattractionsearch {
    extensionName = ThueCat
    pluginName = TouristAttractionSearch
}
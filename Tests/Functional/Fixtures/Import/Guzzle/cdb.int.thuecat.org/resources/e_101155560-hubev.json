      "schema:description": [
        {
          "@language": "de",
          "@value": "Zum Internationalen Museumstag hält das Schillerhaus verschiedene Workshops bereit. Man kann sich zum Beispiel silhouettieren lassen, wie es früher üblich war. Dabei erhält man einen Scherenschnitt vom eigenen Profil. Außerdem gibt es eine Ex Libris Werkstatt. Das sind selbstgestaltete „Namensschilder“ für die Lieblingsbücher. Kaffee und Kuchen gibt’s natürlich auch. Außerdem kommen alle Gäste zum ermäßigten Eintrittspreis ins Museum.\nEintritt frei."
        },
        {
          "@id": "genid-a4133dde22a945bfad9261c7f6eda4245632273-b4",
          "@type": [
            "schema:Thing",
            "schema:Intangible",
            "schema:ComputerLanguage",
            "thuecat:Html"
          ],
          "schema:value": {
            "@language": "de",
            "@value": "Zum Internationalen Museumstag hält das Schillerhaus verschiedene Workshops bereit. Man kann sich zum Beispiel silhouettieren lassen, wie es früher üblich war. Dabei erhält man einen Scherenschnitt vom eigenen Profil. Außerdem gibt es eine Ex Libris Werkstatt. Das sind selbstgestaltete „Namensschilder“ für die Lieblingsbücher. Kaffee und Kuchen gibt’s natürlich auch. Außerdem kommen alle Gäste zum ermäßigten Eintrittspreis ins Museum.<br />Eintritt frei.<br />"
          }
        }
      ],

{
    "name": "werkraummedia/thuecat",
    "description": "Integration of ThueCat into TYPO3 CMS.",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/werkraum-media/thuecat",
    "support": {
        "docs": "https://docs.typo3.org/p/werkraummedia/thuecat/master/en-us/",
        "email": "coding@daniel-siepmann.de",
        "issues": "https://github.com/werkraum-media/thuecat/issues",
        "source": "https://github.com/werkraum-media/thuecat"
    },
    "authors": [
        {
            "name": "Daniel Siepmann",
            "email": "daniel.siepmann@codappix.com",
            "homepage": "https://www.codappix.com/",
            "role": "Developer"
        },
        {
            "name": "Carlos Pozo",
            "email": "carlosricardo.pozo@hotmail.com",
            "homepage": "https://codebycarlos.com/",
            "role": "Templater"
        }
    ],
    "autoload": {
        "psr-4": {
            "WerkraumMedia\\ThueCat\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WerkraumMedia\\ThueCat\\Tests\\": "Tests/"
        }
    },
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "symfony/console": "^7.2",
        "symfony/dependency-injection": "^7.2",
        "symfony/property-access": "^7.2",
        "symfony/property-info": "^7.2",
        "symfony/serializer": "^7.4 || ^8.0",
        "typo3/cms-backend": "^13.4 || 14.*",
        "typo3/cms-core": "^13.4",
        "typo3/cms-extbase": "^13.4 || 14.*",
        "typo3/cms-filelist": "^13.4 || 14.*",
        "typo3/cms-filemetadata": "^13.4 || 14.*",
        "typo3/cms-fluid-styled-content": "^13.4 || 14.*",
        "typo3/cms-frontend": "^13.4 || 14.*",
        "typo3/cms-install": "^13.4 || 14.*"
    },
    "require-dev": {
        "codappix/typo3-php-datasets": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-phpunit": "2.0.16",
        "saschaegerer/phpstan-typo3": "2.1.1 || 3.0.1",
        "staabm/phpstan-todo-by": "^0.3.3",
        "typo3/testing-framework": "^9.4"
    },
    "config": {
        "sort-packages": true,
        "lock": false,
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true,
            "ocramius/package-versions": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "mkdir -p .Build/web/typo3conf/ext/",
            "[ -L .Build/web/typo3conf/ext/thuecat ] || ln -snvf ../../../../. .Build/web/typo3conf/ext/thuecat"
        ]
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "extension-key": "thuecat",
            "web-dir": ".Build/web"
        }
    }
}
